---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import { projectGroups } from "@/lib/constants";
---

<BaseLayout
  title="Products"
  description="関わってきたプロダクトと OSS / personal tools をまとめたページです。"
>
  <section class="page-header">
    <p class="page-header-eyebrow">Products</p>
    <h1 class="page-header-title">プロダクト</h1>
    <p class="page-header-lead">
      仕事で関わってきたプロダクトと、個人で作っている小さなツールをまとめています。
    </p>
  </section>

  <Section
    title="関わってきたもの"
    eyebrow="Products"
    lead="関わってきたプロダクトと、個人で作っているツールです。"
  >
    {
      projectGroups.map((group) => (
        <div class="group-block">
          <p class="meta">{group.title}</p>
          <div class="stack-list">
            {group.items.map((item) => (
              <article class="stack-card">
                <p class="meta">{item.category}</p>
                <h3>
                  {item.href ? (
                    <a href={item.href} target="_blank" rel="noreferrer">
                      {item.title}
                    </a>
                  ) : (
                    item.title
                  )}
                </h3>
                <p>{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      ))
    }
  </Section>

</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import { workingPrinciples } from "@/data/work";
---

<BaseLayout
  title="How I work"
  description="Satoshi Ebisawa がチームで仕事を進めるときに大事にしていることをまとめたページです。"
>
  <section class="page-header">
    <p class="page-header-eyebrow">Approach</p>
    <h1 class="page-header-title">仕事の進め方</h1>
    <p class="page-header-lead">
      チームで前に進むために、普段の仕事で重視していることをまとめています。
    </p>
  </section>

  <Section
    title="大事にしていること"
    eyebrow="Approach"
    lead="仕事を進めるうえで、日々重視していることです。"
  >
    <div class="stack-list">
      {
        workingPrinciples.map((section) => (
          <article class="stack-card">
            <h3>{section.title}</h3>
            <ul class="plain-list">
              {section.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </Section>
</BaseLayout>

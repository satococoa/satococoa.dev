---
import { Icon } from "astro-icon/components";
import Section from "@/components/Section.astro";
import WritingList from "@/components/WritingList.astro";
import { externalLinks } from "@/data/links";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteOwner } from "@/lib/constants";

const skillTags = ["Ruby", "Ruby on Rails", "Go", "TypeScript", "React", "Next.js", "iOS", "Objective-C", "Swift", "SwiftUI", "Terraform", "AWS", "Google Cloud", "LLM", "RAG"];

const capabilities = [
  { label: "Web フロントエンド (React, Next.js)", icon: "lucide:monitor" },
  { label: "バックエンド (Ruby on Rails, Go, TypeScript)", icon: "lucide:server" },
  { label: "インフラ (Terraform, AWS, Google Cloud)", icon: "lucide:cloud" },
  { label: "iOS アプリ開発", icon: "lucide:smartphone" },
  { label: "事業とチームを前に進める技術判断", icon: "lucide:rocket" },
  { label: "LLM アプリケーション / RAG / AI developer tooling", icon: "lucide:bot" },
];

const featuredTopics = [
  { label: "AI を前提にした最近の仕事の進め方", icon: "lucide:brain" },
  { label: "開発に効く Codex やエージェントの使い方", icon: "lucide:zap" },
  { label: "RAG、LLM 基盤、開発者向けの仕組みづくり", icon: "lucide:wrench" },
];
---

<BaseLayout>
  <section class="hero">
    <div class="hero-content">
      <p class="hero-eyebrow">Personal portal</p>
      <div class="hero-identity">
        <img class="hero-avatar" src="/avatar.png" alt="Satoshi Ebisawa" width="72" height="72" />
        <div>
          <h1>Satoshi Ebisawa</h1>
          <p class="hero-role">{siteOwner.role}</p>
        </div>
      </div>
      <p class="hero-handle">@satococoa / ROUTE06 / Tokyo, Japan</p>
      <p class="hero-copy">
        Web プロダクトの開発を中心に、アプリケーション、インフラ、運用、チームづくりをまたいで、ものごとが前に進む状態をつくってきました。
      </p>
      <p class="hero-copy muted">
        最近は AI を前提にした開発体験や、開発者の仕事の進め方に関心を持っています。
      </p>
      <div class="hero-tags">
        {skillTags.map((tag) => <span class="hero-tag">{tag}</span>)}
      </div>
    </div>
  </section>

  <Section
    title="できること"
    eyebrow="Capabilities"
    lead="主に扱ってきた領域です。"
  >
    <ul class="icon-list">
      {capabilities.map((item) => (
        <li>
          <span class="icon-list-icon" aria-hidden="true">
            <Icon name={item.icon} />
          </span>
          <span>{item.label}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section
    title="いま注力していること"
    eyebrow="Focus"
    lead="最近よく取り組んでいるテーマです。"
  >
    <ul class="icon-list">
      {featuredTopics.map((topic) => (
        <li>
          <span class="icon-list-icon" aria-hidden="true">
            <Icon name={topic.icon} />
          </span>
          <span>{topic.label}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section
    title="最新記事"
    eyebrow="Writing"
    lead="Zenn・dev.to・note の最近の記事です。"
  >
    <WritingList />
  </Section>

  <Section
    title="外部リンク"
    eyebrow="Elsewhere"
    lead="発信先や活動先へのリンクです。"
  >
    <ul class="link-grid">
      {
        externalLinks.map((link) => (
          <li>
            <a href={link.href} target="_blank" rel="noreferrer">
              <span class="link-icon" aria-hidden="true">
                <Icon name={link.icon} />
              </span>
              <span>{link.label}</span>
              {link.note && <small>{link.note}</small>}
            </a>
          </li>
        ))
      }
    </ul>
  </Section>
</BaseLayout>

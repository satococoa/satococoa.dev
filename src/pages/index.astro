---
import { Icon } from "astro-icon/components";
import Section from "@/components/Section.astro";
import WritingList from "@/components/WritingList.astro";
import { externalLinks } from "@/data/links";
import { profile } from "@/data/profile";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="hero">
    <div class="hero-content">
      <p class="hero-eyebrow">Personal portal</p>
      <div class="hero-identity">
        <img class="hero-avatar" src="/avatar.png" alt={profile.name} width="72" height="72" />
        <div>
          <h1>{profile.name}</h1>
          <p class="hero-role">{profile.role}</p>
        </div>
      </div>
      <p class="hero-handle">{profile.handle} / {profile.company} / {profile.location}</p>
      <p class="hero-copy">{profile.intro}</p>
      <p class="hero-copy muted">{profile.summary}</p>
      <div class="hero-tags">
        {profile.skillTags.map((tag) => <span class="hero-tag">{tag}</span>)}
      </div>
    </div>
  </section>

  <Section
    title="できること"
    eyebrow="Capabilities"
    lead="主に扱ってきた領域です。"
  >
    <ul class="icon-list">
      {profile.capabilities.map((item) => (
        <li>
          <span class="icon-list-icon" aria-hidden="true">
            <Icon name={item.icon} />
          </span>
          <span>{item.label}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section
    title="いま注力していること"
    eyebrow="Focus"
    lead="最近よく取り組んでいるテーマです。"
  >
    <ul class="icon-list">
      {profile.featuredTopics.map((topic) => (
        <li>
          <span class="icon-list-icon" aria-hidden="true">
            <Icon name={topic.icon} />
          </span>
          <span>{topic.label}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section
    title="最新記事"
    eyebrow="Writing"
    lead="Zenn・dev.to・note の最近の記事です。"
  >
    <WritingList />
  </Section>

  <Section
    title="外部リンク"
    eyebrow="Elsewhere"
    lead="発信先や活動先へのリンクです。"
  >
    <ul class="link-grid">
      {
        externalLinks.map((link) => (
          <li>
            <a href={link.href} target="_blank" rel="noreferrer">
              {link.icon && (
                <span class="link-icon" aria-hidden="true">
                  <Icon name={link.icon} />
                </span>
              )}
              <span>{link.label}</span>
              {link.note && <small>{link.note}</small>}
            </a>
          </li>
        ))
      }
    </ul>
  </Section>
</BaseLayout>
